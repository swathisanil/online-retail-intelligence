    "                                                                     # Use openpyxl engine explicitly\n",
    "df = pd.read_excel(\"C:/Users/swath/Downloads/Copy of Online Retail.xlsx\", sheet_name='cleaned', engine='openpyxl')\n",
    "\n",
    "df.head()"
   ]
